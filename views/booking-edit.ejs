<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5 d-flex justify-content-center">
        <div class="card shadow" style="width: 100%; max-width: 450px;">
            <div class="card-body p-4">

                <div class="d-flex gap-2 mb-4">
                    <a href="/manage-bookings" class="btn btn-outline-secondary btn-sm">Dashboard</a>
                    <a href="/daily-schedule" class="btn btn-outline-secondary btn-sm">Today's Schedule</a>
                    <a href="/create-booking" class="btn btn-outline-secondary btn-sm">New Booking</a>
                </div>

                <h2 class="mb-3">Edit Booking <%= booking.booking_id %></h2>
                <form action="/booking/<%= booking.booking_id %>/edit" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" name="booking_date"
                               value="<%= booking.booking_date.toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Time Slot</label>
                        <select class="form-select" name="time_slot_id" required>
                            <% for(let i=1; i<=11; i++) { %>
                                <option value="<%= i %>" <%= booking.time_slot_id == i ? 'selected' : '' %>>Slot <%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Room</label>
                        <select class="form-select" name="room_id" required>
                            <% rooms.forEach(function(r) { %>
                                <option value="<%= r.room_id %>" <%= booking.room_id === r.room_id ? 'selected' : '' %>>
                                    <%= r.room_name %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Save Changes</button>
                </form>
                <a href="/booking/<%= booking.booking_id %>" class="btn btn-link mt-2">Cancel</a>
            </div>
        </div>
    </div>
</body>
</html>