<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Request Admin Access</title>
</head>
<body>
    <%- include('partials/header') %>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-header bg-warning">
                        <h4 class="mb-0">Request Admin Access</h4>
                    </div>
                    <div class="card-body">
                        <form action="/request-admin_access" method="POST">
                            <div class="mb-3">
                                <label for="reason" class="form-label">Reason for Request</label>
                                <textarea class="form-control" id="reason" name="reason" rows="4" placeholder="Please explain why you need admin access..." required></textarea>
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">Submit Request</button>
                                <a href="/staff-dashboard" class="btn btn-secondary">Cancel</a> 
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>