<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Meeting Rooms</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    
    <div class="container py-5">
        
        <!-- Header with conditional Add Room Button for Admins -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>🏫 Meeting Rooms Dashboard</h2>
            <div>
                <a href="/" class="btn btn-outline-secondary me-2">← Home</a>
                <% if (user && user.role === 'locals.user') { %>
                    <a href="/add-room" class="btn btn-primary">+ Add New Room (Admin)</a>
                <% } %>
            </div>
        </div>

        <!-- Flash Alert Banners -->
        <% if (success && success.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <strong>Success!</strong> <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Error!</strong> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Rooms Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Room ID</th>
                            <th>Room Name</th>
                            <th>Capacity</th>
                            <th>Current Condition</th>
                            <% if (user && (user.role === 'staff' || user.role === 'admin')) { %>
                                <th>Staff Action</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (rooms && rooms.length > 0) { %>
                            <% rooms.forEach(room => { %>
                                <tr>
                                    <td><strong>#<%= room.room_id %></strong></td>
                                    <td><%= room.room_name %></td>
                                    <td><%= room.capacity %> seats</td>
                                    <td>
                                        <% if (room.condition_status === 'Available') { %>
                                            <span class="badge bg-success">Available</span>
                                        <% } else if (room.condition_status === 'Under Maintenance') { %>
                                            <span class="badge bg-danger">Under Maintenance</span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark"><%= room.condition_status || 'Available' %></span>
                                        <% } %>
                                    </td>
                                    
                                    <!-- Action dropdown only visible to Staff or Admin -->
                                    <% if (user && (user.role === 'staff' || user.role === 'admin')) { %>
                                        <td>
                                            <form action="/update-room-status" method="POST" class="d-flex gap-2">
                                                <input type="hidden" name="room_id" value="<%= room.room_id %>">
                                                <select name="condition_status" class="form-select form-select-sm" style="width: 170px;">
                                                    <option value="Available" <%= room.condition_status === 'Available' ? 'selected' : '' %>>Available</option>
                                                    <option value="Under Maintenance" <%= room.condition_status === 'Under Maintenance' ? 'selected' : '' %>>Under Maintenance</option>
                                                    <option value="Cleaning" <%= room.condition_status === 'Cleaning' ? 'selected' : '' %>>Cleaning</option>
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                            </form>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No rooms found in the database.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
    
    <script href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>