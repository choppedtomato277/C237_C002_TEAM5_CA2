<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meeting Rooms Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <%- include('partials/header') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>🏫 Meeting Rooms Dashboard</h2>

            <% if (user && user.role === 'admin') { %>
                <a href="/add-room" class="btn btn-primary fw-bold">+ Add New Room</a>
            <% } %>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Room ID</th>
                            <th>Room Name</th>
                            <th>Capacity</th>
                            <th>Condition</th>
                            <% if (user && (user.role === 'admin' || user.role === 'staff')) { %>
                                <th>Update Condition</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (rooms && rooms.length > 0) { %>
                            <% rooms.forEach(room => { %>
                                <tr>
                                    <td class="fw-bold"><%= room.room_id %></td>
                                    <td><%= room.room_name %></td>
                                    <td><%= room.capacity %> seats</td>
                                    <td>
                                        <span class="badge <%= room.condition_status === 'Available' ? 'bg-success' : 'bg-warning text-dark' %>">
                                            <%= room.condition_status || 'Available' %>
                                        </span>
                                    </td>

                                    <% if (user && (user.role === 'admin' || user.role === 'staff')) { %>
                                        <td>
                                            <form action="/update-room-status" method="POST" class="d-flex gap-2">
                                                <input type="hidden" name="room_id" value="<%= room.room_id %>">
                                                <select name="condition_status" class="form-select form-select-sm" onchange="this.form.submit()">
                                                    <option value="Available" <%= room.condition_status === 'Available' ? 'selected' : '' %>>Available</option>
                                                    <option value="Under Maintenance" <%= room.condition_status === 'Under Maintenance' ? 'selected' : '' %>>Under Maintenance</option>
                                                    <option value="Disabled" <%= room.condition_status === 'Disabled' ? 'selected' : '' %>>Disabled</option>
                                                </select>
                                            </form>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No rooms found in database.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>