<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Review - Study Room Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .stars {
            display: inline-flex;
            flex-direction: row-reverse;
            font-size: 2rem;
        }
        .stars input {
            display: none;
        }
        .stars label {
            color: #ccc;
            cursor: pointer;
            transition: color 0.15s;
        }
        .stars input:checked ~ label,
        .stars label:hover,
        .stars label:hover ~ label {
            color: #f5b301;
        }
    </style>
</head>
<body class="bg-light">
    <%- include('partials/header') %>
    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow" style="width: 100%; max-width: 400px;">
            <div class="card-body p-4">
                <h2 class="text-center mb-3">Review</h2>
                <% if (success && success.length) { %>
                    <div class="alert alert-success" role="alert"><%= success %></div>
                <% } %>
                <% if (error && error.length) { %>
                    <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>
                <form action="/review" method="POST">
                    <div class="mb-3">
                        <label for="room_id" class="form-label">Select Room</label>
                        <select class="form-select" id="room_id" name="room_id" required>
                            <option value="" disabled selected>Select a room</option>
                            <% if (rooms && rooms.length > 0) { %>
                                <% rooms.forEach((room) => { %>
                                    <option value="<%= room.room_id %>"><%= room.room_name %> (<%= room.room_id %>)</option>
                                <% }) %>
                            <% } else { %>
                                <option value="" disabled>No rooms available</option>
                            <% } %>
                        </select>
                    </div>
                    <div class="mb-3 text-center">
                        <label class="form-label d-block">Review Score</label>
                        <div class="stars">
                            <input type="radio" id="star5" name="score" value="5">
                            <label for="star5">★</label>
                            <input type="radio" id="star4" name="score" value="4" >
                            <label for="star4">★</label>
                            <input type="radio" id="star3" name="score" value="3">
                            <label for="star3">★</label>
                            <input type="radio" id="star2" name="score" value="2">
                            <label for="star2">★</label>
                            <input type="radio" id="star1" name="score" value="1">
                            <label for="star1">★</label>
                        </div>
                    </div>
                    <div class="mb-4">
                        <textarea class="form-control" id="review" name="review" rows="4" maxlength="255" placeholder="Share your experiences about this room here" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Submit</button>
                </form>

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>