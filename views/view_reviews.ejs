<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Reviews - Study Room Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f5f7fb;
        }

        .reviews-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
            overflow: hidden;
        }

        .reviews-table thead {
            background: linear-gradient(135deg, #0d6efd, #0b5ed7);
            color: white;
        }

        .reviews-table thead th {
            border: none;
            font-weight: 600;
        }

        .reviews-table tbody tr:hover {
            background-color: #eef6ff;
        }

        .reviews-table td, .reviews-table th {
            padding: 14px 16px;
            vertical-align: middle;
        }

        .page-title {
            color: #0d6efd;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>

    <div class="container my-5">
        <h2 class="page-title mb-4">Reviews</h2>
        <% if (reviews && reviews.length > 0) { %>
            <div class="reviews-card p-3">
                <div class="table-responsive">
                    <table class="table table-striped reviews-table mb-0">
                        <thead>
                            <tr>
                                <th>Review ID</th>
                                <th>User Email</th>
                                <th>Room ID</th>
                                <th>Review Score</th>
                                <th>Review</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reviews.forEach((review) => { %>
                                <tr>
                                    <td><%= review.review_id %></td>
                                    <td><%= review.user_email %></td>
                                    <td><%= review.room_id %></td>
                                    <td><%= review.review_score %></td>
                                    <td><%= review.review %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } else { %>
            <div class="alert alert-info">No reviews found.</div>
        <% } %>
    </div>
</body>