<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5 d-flex justify-content-center">
        <div class="card shadow" style="width: 100%; max-width: 500px;">
            <div class="card-body p-4">

                <div class="d-flex gap-2 mb-4">
                    <a href="/manage-bookings" class="btn btn-outline-secondary btn-sm">Dashboard</a>
                    <a href="/daily-schedule" class="btn btn-outline-secondary btn-sm">Today's Schedule</a>
                    <a href="/create-booking" class="btn btn-outline-secondary btn-sm">New Booking</a>
                </div>

                <h2 class="mb-3">Booking Details</h2>
                <table class="table">
                    <tr><th>Booking ID</th><td><%= booking.booking_id %></td></tr>
                    <tr><th>Date</th><td><%= new Date(booking.booking_date).toLocaleDateString() %></td></tr>
                    <tr><th>Time Slot</th><td><%= booking.time_slot_id %></td></tr>
                    <tr><th>Room</th><td><%= booking.room_name %> (capacity: <%= booking.capacity %>)</td></tr>
                    <tr><th>Booked By</th><td><%= booking.booked_by %> (<%= booking.email %>)</td></tr>
                    <tr><th>Status</th><td><%= booking.status %></td></tr>
                </table>
                <a href="/booking/<%= booking.booking_id %>/edit" class="btn btn-primary">Edit Booking</a>
                <a href="/daily-schedule" class="btn btn-secondary">Back to Schedule</a>
            </div>
        </div>
    </div>
</body>
</html>