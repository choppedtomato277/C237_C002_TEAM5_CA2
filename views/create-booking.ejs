<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Booking - Study Room Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow" style="width: 100%; max-width: 450px;">
            <div class="card-body p-4">

                <div class="d-flex gap-2 mb-4">
                    <a href="/manage-bookings" class="btn btn-outline-secondary btn-sm">Dashboard</a>
                    <a href="/daily-schedule" class="btn btn-outline-secondary btn-sm">Today's Schedule</a>
                    <a href="/create-booking" class="btn btn-outline-secondary btn-sm">New Booking</a>
                </div>

                <h2 class="text-center mb-3">Create a Booking</h2>
                <p class="text-center text-muted">Booking as: <strong><%= user.name %></strong></p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-danger"><%= error[0] %></div>
                <% } %>

                <% if (rooms.length === 0) { %>
                    <div class="alert alert-warning">No rooms are currently available for booking.</div>
                <% } %>

                <form action="/create-booking" method="POST">
                    <div class="mb-3">
                        <label for="booking_date" class="form-label">Date</label>
                        <input type="date" class="form-control" id="booking_date" name="booking_date" required>
                    </div>
                    <div class="mb-3">
                        <label for="time_slot_id" class="form-label">Time Slot</label>
                    <select class="form-select" id="time_slot_id" name="time_slot_id" required>
                         <option value="1">Slot 1 (9am - 10am)</option>
                        <option value="2">Slot 2 (10am - 11am)</option>
                        <option value="3">Slot 3 (11am - 12pm)</option>
                        <option value="4">Slot 4 (12pm - 1pm)</option>
                        <option value="5">Slot 5 (1pm - 2pm)</option>
                        <option value="6">Slot 6 (2pm - 3pm)</option>
                        <option value="7">Slot 7 (3pm - 4pm)</option>
                        <option value="8">Slot 8 (4pm - 5pm)</option>
                        <option value="9">Slot 9 (5pm - 6pm)</option>
                        <option value="10">Slot 10 (6pm - 7pm)</option>
                        <option value="11">Slot 11 (7pm - 8pm)</option>
                    </select>
                    </div>
                    <div class="mb-4">
                        <label for="room_id" class="form-label">Room</label>
                        <select class="form-select" id="room_id" name="room_id" required>
                            <% rooms.forEach(function(r) { %>
                                <option value="<%= r.room_id %>">
                                    <%= r.room_name %> (capacity: <%= r.capacity %><% if (r.has_whiteboard) { %>, whiteboard<% } %><% if (r.has_projector) { %>, projector<% } %>)
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Book Room</button>
                </form>

                <div class="text-center mt-3">
                    <a href="/daily-schedule">← Back to schedule</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>