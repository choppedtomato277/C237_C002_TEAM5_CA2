<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Room - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 500px;">
        <a href="/view-rooms" class="btn btn-outline-secondary btn-sm mb-3">← Back to Rooms List</a>
        
        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>

        <div class="card shadow-sm border-0 p-4">
            <h3 class="mb-3">➕ Add New Room (Admin)</h3>
            <form action="/add-room" method="POST">
                <div class="mb-3">
                    <label class="form-label font-weight-bold">Room Name / Number</label>
                    <input type="text" name="room_name" class="form-control" placeholder="e.g. Lab 302 or Discussion Room A" required>
                </div>
                <div class="mb-3">
                    <label class="form-label font-weight-bold">Max Capacity</label>
                    <input type="number" name="capacity" class="form-control" placeholder="e.g. 10" min="1" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Save Room into MySQL</button>
            </form>
        </div>
    </div>
</body>
</html>