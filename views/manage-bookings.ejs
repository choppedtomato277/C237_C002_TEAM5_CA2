
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Bookings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="card shadow">
            <div class="card-body p-4">

                <div class="d-flex gap-2 mb-4">
                    <a href="/manage-bookings" class="btn btn-outline-secondary btn-sm">Dashboard</a>
                    <a href="/daily-schedule" class="btn btn-outline-secondary btn-sm">Today's Schedule</a>
                    <a href="/create-booking" class="btn btn-outline-secondary btn-sm">New Booking</a>
                </div>

                <h2 class="mb-1">Manage Bookings</h2>
                <p class="text-muted">Logged in as: <strong><%= user.name %></strong> (<%= user.role %>)</p>

                <h5>Recent Bookings</h5>

                <form method="GET" action="/manage-bookings" class="mb-3" style="max-width: 250px;">
                    <label for="status" class="form-label">Filter by status</label>
                    <select name="status" id="status" class="form-select" onchange="this.form.submit()">
                        <option value="all" <%= statusFilter === 'all' ? 'selected' : '' %>>All</option>
                        <option value="confirmed" <%= statusFilter === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="no-show" <%= statusFilter === 'no-show' ? 'selected' : '' %>>No-Show</option>
                        <option value="cancelled" <%= statusFilter === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </form>

                <% if (recentBookings.length === 0) { %>
                    <p class="text-center text-muted py-4">No bookings match this filter.</p>
                <% } else { %>
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Booking ID</th><th>Date</th><th>Room</th><th>Booked By</th><th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentBookings.forEach(function(b) { %>
                                <tr>
                                    <td><a href="/booking/<%= b.booking_id %>"><%= b.booking_id %></a></td>
                                    <td><%= new Date(b.booking_date).toLocaleDateString() %></td>
                                    <td><%= b.room_name %></td>
                                    <td><%= b.booked_by %></td>
                                    <td>
                                        <% if (b.status === 'confirmed') { %><span class="badge bg-success">Confirmed</span>
                                        <% } else if (b.status === 'no-show') { %><span class="badge bg-danger">No-Show</span>
                                        <% } else { %><span class="badge bg-secondary"><%= b.status %></span><% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>

                <a href="/">← Back to home</a>
            </div>
        </div>
    </div>
</body>
</html>