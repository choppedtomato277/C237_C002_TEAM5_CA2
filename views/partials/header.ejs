<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">Meeting Room Booking — C237_002_TEAM5_CA2</a>
        <div class="navbar-nav ms-auto">
            <% if (user) { %>
                <span class="nav-item nav-link text-muted">Welcome, <%= user.name %></span>

                <!-- Everyone sees Dashboard & Can submit a review -->
                <a class="nav-item nav-link text-primary" href="/view-rooms">Rooms</a>

                <!-- Admin only: Flag Misuse -->
                <% if (user.role === 'admin') { %>
                    <a class="nav-item nav-link text-primary" href="/staff-dashboard">Flag Misuse</a>
                <% } %>

                <!-- Staff only: Staff Dashboard -->
                <% if (user.role === 'staff') { %>
                    <a class="nav-item nav-link text-primary" href="/staff-dashboard">Flag Misuse</a>
                    <a class="nav-item nav-link text-primary" href="/view_reviews">Reviews</a>
                <% } %>

                <!-- Employee only -->
                <% if (user.role === 'employee') { %>
                    <a class="nav-item nav-link text-primary" href="/review_form">Submit Reviews</a>
                    <!-- My Bookings & Request Admin Access available in Quick Links on homepage -->
                <% } %>

                <a class="nav-item nav-link text-danger" href="/logout">Logout</a>
            <% } else { %>
                <a class="nav-item nav-link" href="/login">Login</a>
                <a class="nav-item nav-link text-primary" href="/register">Register</a>
            <% } %>
        </div>
    </div>
</nav>