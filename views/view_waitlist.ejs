<!-- KHOON YONG - START -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Waitlist - Study Room Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/header', { user: user }) %>

    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">View Waitlist</h1>
                <p class="text-muted mb-0">
                    <%= viewingAll ? 'All active waitlist entries.' : 'Your active waitlist entries.' %>
                </p>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <% if (user.role === 'employee' || user.role === 'staff') { %>
                    <a href="/create-waitlist" class="btn btn-primary">Join Waitlist</a>
                <% } %>
                <span class="badge text-bg-primary rounded-pill"><%= waitlist.length %> active</span>
            </div>
        </div>

        <% if (waitlist.length === 0) { %>
            <div class="alert alert-info">There are no active waitlist entries to show.</div>
        <% } else { %>
            <div class="table-responsive bg-white rounded shadow-sm">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Room</th>
                            <th scope="col">Booking Date</th>
                            <th scope="col">Time Slot</th>
                            <% if (viewingAll) { %><th scope="col">Employee</th><% } %>
                            <th scope="col">Waitlist ID</th>
                            <% if (!viewingAll) { %><th scope="col">Action</th><% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% waitlist.forEach((entry) => { %>
                            <tr>
                                <td><%= entry.room_id %></td>
                                <td><%= new Date(entry.waitlist_booking_date).toLocaleDateString() %></td>
                                <td><%= entry.time_slot_id %></td>
                                <% if (viewingAll) { %><td><%= entry.email %></td><% } %>
                                <td><%= entry.waitlist_id %></td>
                                <% if (!viewingAll) { %>
                                <td>
                                    <button class="btn btn-sm btn-danger cancel-waitlist-btn" 
                                            data-waitlist-id="<%= entry.waitlist_id %>">
                                        Cancel
                                    </button>
                                </td>
                                <% } %>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </main>

    <script>
        // Cancel waitlist functionality
        document.querySelectorAll('.cancel-waitlist-btn').forEach(button => {
            button.addEventListener('click', async function() {
                if (!confirm('Are you sure you want to cancel this waitlist entry?')) {
                    return;
                }
                
                const waitlistId = this.dataset.waitlistId;
                
                try {
                    const response = await fetch('/cancel-waitlist', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ waitlist_id: waitlistId })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        alert('Waitlist entry cancelled successfully.');
                        location.reload();
                    } else {
                        alert(data.error || 'Failed to cancel waitlist entry.');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while cancelling.');
                }
            });
        });
    </script>
</body>
</html>
<!-- KHOON YONG - END -->
