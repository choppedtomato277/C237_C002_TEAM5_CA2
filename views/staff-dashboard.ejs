<!DOCTYPE html>
<html>
<head>
  <title>Staff Dashboard</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-4">
    <h1>Staff Dashboard</h1>

    <% employees.forEach(employee => { %>
      <div class="card mb-3">
        <div class="card-body">
          <p class="mb-1"><strong>Name:</strong> <%= employee.name %></p>
          <p class="mb-1"><strong>Email:</strong> <%= employee.email %></p>
          <p class="mb-3"><strong>Current misuse flags:</strong> <%= employee.misuse_flag || 0 %></p>

          <form action="/add-misuse-flag" method="POST">
            <input type="hidden" name="email" value="<%= employee.email %>">
            <button type="submit" class="btn btn-warning">Add Misuse Flag</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</body>
</html>