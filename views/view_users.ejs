<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Users - Meeing Room Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container mt-4">
        <h1>Users</h1>

        <% if (users && users.length > 0) { %>
            <table class="table table-hover">
                <thead class="table">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (var i = 0; i < users.length; i++) { %>
                        <% var userItem = users[i]; %>
                        <tr>
                            <td><%= userItem.name %></td>
                            <td><%= userItem.email %></td>
                            <td><%= userItem.role || 'user' %></td>
                            <td><%= userItem.created_at ? new Date(userItem.created_at).toLocaleDateString() : 'N/A' %></td>
                            <td>
                                <% if (userItem.role !== 'admin') { %>
                                    <form action="/delete-user/<%= encodeURIComponent(userItem.email) %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                <% } else { %>
                                    <span class="text-muted">Cannot delete</span>
                                <% } %>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        <% } else { %>
            <div class="text-center py-5 text-muted">
                <p>No users found.</p>
            </div>
        <% } %>
    </div>
</body>
</html>
