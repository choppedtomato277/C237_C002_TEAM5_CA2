<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Admin Access Requests - Study Room Booking</title>
    <%- include('partials/header') %>
</head>
<body>
    <div class="container mt-4">
        <h2 class="mb-4">Manage Admin Access Requests</h2>

        <% if (requests && requests.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>User Email</th>
                            <th>Submitted Time</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (var i = 0; i < requests.length; i++) { %>
                            <% var req = requests[i]; %>
                            <tr>
                                <td><%= req.email %></td>
                                <td><%= req.requested_at ? new Date(req.requested_at).toLocaleString() : 'N/A' %></td>
                                <td><%= req.reason || 'No reason provided' %></td>
                                <td>
                                    <% if (req.status === 'pending') { %>
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    <% } else if (req.status === 'approved') { %>
                                        <span class="badge bg-success">Approved</span>
                                    <% } else if (req.status === 'rejected') { %>
                                        <span class="badge bg-danger">Rejected</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><%= req.status %></span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (req.status === 'pending') { %>
                                        <form action="/admin_access_requests/<%= req.id %>/approve" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                        </form>
                                        <form action="/admin_access_requests/<%= req.id %>/reject" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-muted">No actions available</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info">
                No admin access requests found.
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
